---
/**
 * Header button that collapses / expands the left nav sidebar, giving the
 * content column the sidebar's width back. Useful on pages with wide content
 * (the architecture Mermaid diagrams in particular).
 *
 * State lives in `data-sidebar-collapsed` on <html> and is persisted to
 * localStorage. The initial value is applied by an inline head script (see
 * astro.config.mjs) so there's no flash of the wrong layout on load.
 *
 * Desktop only — below Starlight's 50rem breakpoint the sidebar pane *is* the
 * mobile menu, so collapsing it would break navigation.
 */
---

<button
	type="button"
	class="sidebar-toggle"
	aria-pressed="false"
	aria-controls="starlight__sidebar"
	title="Toggle sidebar"
>
	<span class="sr-only">Toggle sidebar</span>
	<svg
		aria-hidden="true"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="1.8"
		stroke-linecap="round"
		stroke-linejoin="round"
	>
		<rect x="3" y="4" width="18" height="16" rx="2"></rect>
		<line x1="9" y1="4" x2="9" y2="20"></line>
	</svg>
</button>

<style>
	.sidebar-toggle {
		display: none;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		padding: 0;
		border: 0;
		border-radius: 0.375rem;
		background: transparent;
		color: var(--sl-color-text-accent);
		cursor: pointer;
	}

	/* Only meaningful where the sidebar is a real column. */
	@media (min-width: 50rem) {
		.sidebar-toggle {
			display: flex;
		}
	}

	/* Beats the display:flex above — the UA sheet's [hidden] rule would not.
	   Set by the script on splash pages, which have no sidebar. */
	.sidebar-toggle[hidden] {
		display: none;
	}

	.sidebar-toggle:hover,
	.sidebar-toggle:focus-visible {
		background: var(--sl-color-gray-6, var(--sl-color-gray-5));
		color: var(--sl-color-white);
	}

	.sidebar-toggle svg {
		width: 1.25rem;
		height: 1.25rem;
	}

	/* Fill the pane indicator when the sidebar is showing. */
	.sidebar-toggle line {
		transition: opacity 0.15s ease;
	}

	:global(html[data-sidebar-collapsed]) .sidebar-toggle line {
		opacity: 0.35;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
</style>

<script>
	const KEY = 'nexis-wiki:sidebar-collapsed';

	function sync(button: HTMLButtonElement) {
		const collapsed = document.documentElement.hasAttribute('data-sidebar-collapsed');
		button.setAttribute('aria-pressed', String(collapsed));
		button.title = collapsed ? 'Show sidebar' : 'Hide sidebar';
	}

	function setup() {
		const button = document.querySelector<HTMLButtonElement>('.sidebar-toggle');
		if (!button) return;

		// Splash pages (the homepage) render no sidebar. A toggle there would
		// shift the content with nothing to reveal, so hide it outright.
		if (!document.querySelector('.sidebar-pane')) {
			button.hidden = true;
			return;
		}
		button.hidden = false;

		sync(button);

		button.addEventListener('click', () => {
			const root = document.documentElement;
			const collapsed = root.hasAttribute('data-sidebar-collapsed');

			if (collapsed) {
				root.removeAttribute('data-sidebar-collapsed');
			} else {
				root.setAttribute('data-sidebar-collapsed', '');
			}

			try {
				localStorage.setItem(KEY, collapsed ? '0' : '1');
			} catch {
				// Private mode / storage disabled — the toggle still works for this page.
			}

			sync(button);
			// Mermaid sizes to its container, and xterm-style fit logic elsewhere
			// listens for the same signal. Nudge anything width-sensitive.
			window.dispatchEvent(new Event('resize'));
		});
	}

	setup();
	// Starlight uses view transitions; re-bind after each navigation.
	document.addEventListener('astro:page-load', setup);
</script>
